{
  "name": "task-manager",
  "private": true,
  "version": "0.0.0",
  "description": "Agile task board with Copilot integration",
  "author": "Cliff Parker",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "postinstall": "node scripts/relocate-electron-install.js",
    "desktop": "node_modules/.electron-vendor/cli.js .",
    "desktop:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && node_modules/.electron-vendor/cli.js .\"",
    "desktop:dist": "npm run build && TASKLANE_USE_DIST=1 node_modules/.electron-vendor/cli.js .",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "release:patch": "npm version patch --no-git-tag-version && npm run dist",
    "release:minor": "npm version minor --no-git-tag-version && npm run dist",
    "release:major": "npm version major --no-git-tag-version && npm run dist"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.tasklane.app",
    "productName": "Tasklane",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  }
}
